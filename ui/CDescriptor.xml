<GuiXml>
  <Controls>
    <TopLevelControl name="CDescriptorWindow" hidden="true" clampedToScreen="true" movable="true" mouseEnabled="true">
      <Anchor point="CENTER"/>
      <Dimensions x="620" y="530"/>
      <OnMoveStop>CDescriptor.UI.on_move_stop()</OnMoveStop>
      <Controls>

        <Backdrop name="$(parent)Bg" inherits="ZO_DefaultBackdrop">
          <AnchorFill/>
        </Backdrop>

        <Label name="$(parent)Title" font="ZoFontHeader" color="1,0.8,0,1" text="Character Descriptor">
          <Anchor point="TOP" offsetY="14"/>
        </Label>

        <Button name="$(parent)CloseButton" inherits="ZO_CloseButton">
          <Anchor point="TOPRIGHT" offsetX="-4" offsetY="4"/>
          <OnClicked>CDescriptorWindow:SetHidden(true)</OnClicked>
        </Button>

        <!-- Boton Generar -->
        <Button name="$(parent)GenerateButton" inherits="ZO_DefaultButton">
          <Dimensions x="130" y="32"/>
          <Anchor point="TOPLEFT" offsetX="20" offsetY="50"/>
          <OnClicked>CDescriptor.UI.on_generate()</OnClicked>

        </Button>

        <!-- Estado (reemplaza la barra de progreso) -->
        <Label name="$(parent)StatusLabel" font="ZoFontGameSmall" color="0.7,0.7,0.7,1" text="">
          <Anchor point="LEFT" relativeTo="$(parent)GenerateButton" relativePoint="RIGHT" offsetX="12"/>
        </Label>

        <!-- Output: Backdrop scrollable con EditBox seleccionable -->
        <Backdrop name="$(parent)OutputBg" inherits="ZO_MultiLineEditBackdrop_Keyboard">
          <Anchor point="TOPLEFT" offsetX="20" offsetY="96"/>
          <Anchor point="BOTTOMRIGHT" offsetX="-20" offsetY="-54"/>
          <Controls>
            <EditBox name="$(parent)OutputBox" inherits="ZO_DefaultEditMultiLineForBackdrop" maxInputCharacters="100000">
            </EditBox>
          </Controls>
        </Backdrop>

        <!-- Boton Copy: llama CopyToClipboard directamente (funcion protegida) -->
        <Button name="$(parent)CopyButton" inherits="ZO_DefaultButton">
          <Dimensions x="130" y="32"/>
          <Anchor point="BOTTOMRIGHT" offsetX="-20" offsetY="-14"/>
          <OnClicked>CopyToClipboard(CDescriptorWindowOutputBox:GetText())</OnClicked>
        </Button>

      </Controls>
    </TopLevelControl>
  </Controls>
</GuiXml>
