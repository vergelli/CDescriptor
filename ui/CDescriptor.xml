<GuiXml>
  <Controls>
    <TopLevelControl name="CDescriptorWindow" hidden="true" clampedToScreen="true" movable="true" mouseEnabled="true">
      <Anchor point="CENTER"/>
      <Dimensions x="620" y="530"/>
      <OnMoveStop>CDescriptor.UI.on_move_stop()</OnMoveStop>
      <OnInitialized>CDescriptor.UI.on_initialized(self)</OnInitialized>
      <Controls>

        <Backdrop name="$(parent)Bg" inherits="ZO_DefaultBackdrop">
          <AnchorFill/>
        </Backdrop>

        <!-- Titulo -->
        <Label name="$(parent)Title" font="ZoFontHeader" color="1,0.8,0,1" text="CDescriptor">
          <Anchor point="TOP" offsetY="14"/>
        </Label>

        <!-- Boton cerrar -->
        <Button name="$(parent)CloseButton" inherits="ZO_CloseButton">
          <Anchor point="TOPRIGHT" offsetX="-4" offsetY="4"/>
          <OnClicked>CDescriptorWindow:SetHidden(true)</OnClicked>
        </Button>

        <!-- Boton Generar -->
        <Button name="$(parent)GenerateButton" inherits="ZO_DefaultButton">
          <Dimensions x="130" y="32"/>
          <Anchor point="TOPLEFT" offsetX="20" offsetY="50"/>
          <OnClicked>CDescriptor.UI.on_generate()</OnClicked>
        </Button>

        <!-- Barra de progreso -->
        <StatusBar name="$(parent)ProgressBar" minimumValue="0" maximumValue="3" value="0">
          <Dimensions x="440" y="18"/>
          <Anchor point="TOPLEFT" offsetX="165" offsetY="55"/>
        </StatusBar>

        <!-- Etiqueta de estado -->
        <Label name="$(parent)ProgressLabel" font="ZoFontGameSmall" color="0.7,0.7,0.7,1" text="">
          <Anchor point="TOPLEFT" relativeTo="$(parent)ProgressBar" relativePoint="BOTTOMLEFT" offsetY="2"/>
        </Label>

        <!-- Caja de output -->
        <EditBox name="$(parent)OutputBox" multiLine="true" maxInputCharacters="65000" font="ZoFontGameSmall">
          <Dimensions x="576" y="370"/>
          <Anchor point="TOPLEFT" offsetX="22" offsetY="100"/>
        </EditBox>

        <!-- Boton Copy -->
        <Button name="$(parent)CopyButton" inherits="ZO_DefaultButton">
          <Dimensions x="130" y="32"/>
          <Anchor point="BOTTOMRIGHT" offsetX="-20" offsetY="-14"/>
          <OnClicked>CDescriptor.UI.on_copy()</OnClicked>
        </Button>

      </Controls>
    </TopLevelControl>
  </Controls>
</GuiXml>
